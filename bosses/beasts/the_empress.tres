[resource]
script = ExtResource("2_akfb2")
id = "the_empress"
riddle_texts = Array[String](["I am the smothering mother who feeds on growth.", "The 34th Law is forbidden, though the body says otherwise.", "I give without counting. I grow without asking.", "My cradle is a jungle; my gift is a vine that never lets go.", "I bloom in your lungs, I root in your streets — what am I?"])
correct_card = "the_empress"
upright_outcome = "It reacts to the card you are holding, cracks forming in the statue. Suddenly, the statue shatters. Their existence from Teranilus fades into silence and disappears forever."
reversed_outcome = "It reacts to the card you are holding, cracks forming in the statue. Suddenly, a loud roar erupts, the statue no longer stone but a proper beast. Their dominion over Teranilus is now sealed, granting them freedom from their stone form."
rejection_hint = "It doesn't react. It appears what you hold doesn't do anything."
